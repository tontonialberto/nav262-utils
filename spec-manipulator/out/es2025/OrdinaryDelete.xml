<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _desc_ be ? &lt;emu-meta effects=&#34;user-code&#34;&gt;_O_.[[GetOwnProperty]]&lt;/emu-meta&gt;(_P_).           1. If _desc_ is *undefined*, return *true*.           1. If _desc_.[[Configurable]] is *true*, then             1. Remove the own property with name _P_ from _O_.             1. Return *true*.           1. Return *false*.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="OrdinaryDelete" retTy="either a normal completion containing a Boolean or a throw completion" id="sec-ordinarydelete" virtualPackage="10 Ordinary and Exotic Objects Behaviours.1 Ordinary Object Internal Methods and Internal Slots.10 [[Delete]] ( P ).1 OrdinaryDelete ( O, P )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="O" ty="an Object"/>
         </params>
         <params>
            <NormalParam name="P" ty="a Symbol or a String"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="desc"/>
                           </variable>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
