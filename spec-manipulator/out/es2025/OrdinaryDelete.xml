                                          </PropertyReference>
                                       </ref>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="P"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeMethodExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="desc"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <UndefinedLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <ReturnStep>
                                 <expr>
                                    <TrueLiteral/>
                                 </expr>
                              </ReturnStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="desc"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="Configurable"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <TrueLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <YetStep>
                                                   <expr>
                                                      <YetExpression str="Remove the own property with name _P_ from _O_." block="null"/>
                                                   </expr>
                                                </YetStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <ReturnStep>
                                                   <expr>
                                                      <TrueLiteral/>
                                                   </expr>
                                                </ReturnStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <FalseLiteral/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
