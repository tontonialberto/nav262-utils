<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _generatorKind_ be GetGeneratorKind().           1. If _generatorKind_ is ~async~, return ? AsyncGeneratorYield(? Await(_value_)).           1. Otherwise, return ? GeneratorYield(CreateIteratorResultObject(_value_, *false*)).         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="Yield" retTy="either a normal completion containing an ECMAScript language value or an abrupt completion" id="sec-yield" virtualPackage="27 Control Abstraction Objects.5 Generator Objects.3 Generator Abstract Operations.7 Yield ( value )" location="https://tc39.es/ecma262/2025/">
