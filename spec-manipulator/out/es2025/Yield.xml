                                       <expr>
                                          <InvokeAbstractOperationExpression name="GeneratorYield">
                                             <args>
                                                <InvokeAbstractOperationExpression name="CreateIteratorResultObject">
                                                   <args>
                                                      <ReferenceExpression>
                                                         <ref>
                                                            <Variable name="value"/>
                                                         </ref>
                                                      </ReferenceExpression>
