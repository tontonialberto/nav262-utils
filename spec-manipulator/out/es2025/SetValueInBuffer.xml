                                       <ref>
                                          <Variable name="isLittleEndian"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <op>
                                    <Present/>
                                 </op>
                              </PredicateCondition>
                           </cond>
