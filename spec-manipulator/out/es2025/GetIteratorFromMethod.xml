<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Let _iterator_ be ? Call(_method_, _obj_).         1. If _iterator_ is not an Object, throw a *TypeError* exception.         1. Return ? GetIteratorDirect(_iterator_).       ">
   <head>
