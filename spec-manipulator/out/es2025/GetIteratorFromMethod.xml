                                                <Variable name="method"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="obj"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <TypeCheckCondition negation="true">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="iterator"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <ty>
                                    <Type value="an Object"/>
                                 </ty>
                              </TypeCheckCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
