         <params>
            <NormalParam name="obj" ty="an ECMAScript language value"/>
         </params>
         <params>
            <NormalParam name="method" ty="a function object"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="iterator"/>
                           </variable>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
                                    <InvokeAbstractOperationExpression name="Call">
                                       <args>
                                          <ReferenceExpression>
