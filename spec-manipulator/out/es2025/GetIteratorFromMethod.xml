                                             <ref>
                                                <Variable name="iterator"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
