                                       <ref>
                                          <Variable name="func"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <UndefinedLiteral/>
                                 </right>
                                 <right>
                                    <NullLiteral/>
