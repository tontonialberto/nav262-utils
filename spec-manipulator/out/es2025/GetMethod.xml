<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Let _func_ be ? GetV(_V_, _P_).         1. If _func_ is either *undefined* or *null*, return *undefined*.         1. If IsCallable(_func_) is *false*, throw a *TypeError* exception.         1. Return _func_.       ">
   <head>
