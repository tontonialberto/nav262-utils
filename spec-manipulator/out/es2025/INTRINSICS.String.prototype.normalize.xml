                           </thenStep>
                           <elseStep>
                              <LetStep>
                                 <variable>
                                    <Variable name="f"/>
                                 </variable>
                                 <expr>
                                    <ReturnIfAbruptExpression check="true">
                                       <expr>
                                          <InvokeAbstractOperationExpression name="ToString">
                                             <args>
                                                <ReferenceExpression>
