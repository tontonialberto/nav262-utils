<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Let _internalSlotsList_ be « [[Prototype]], [[Extensible]] ».         1. If _additionalInternalSlotsList_ is present, set _internalSlotsList_ to the list-concatenation of _internalSlotsList_ and _additionalInternalSlotsList_.         1. Let _O_ be MakeBasicObject(_internalSlotsList_).         1. Set _O_.[[Prototype]] to _proto_.         1. Return _O_.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="OrdinaryObjectCreate" retTy="an Object" id="sec-ordinaryobjectcreate" virtualPackage="10 Ordinary and Exotic Objects Behaviours.1 Ordinary Object Internal Methods and Internal Slots.12 OrdinaryObjectCreate ( proto [ , additionalInternalSlotsList ] )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="proto" ty="an Object or *null*"/>
         </params>
         <params>
            <OptionalParam name="additionalInternalSlotsList" ty="a List of names of internal slots"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="internalSlotsList"/>
                           </variable>
                           <expr>
                              <ListExpression>
                                 <entries>
                                    <FieldLiteral name="Prototype"/>
                                 </entries>
                                 <entries>
                                    <FieldLiteral name="Extensible"/>
                                 </entries>
                              </ListExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <PredicateCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="additionalInternalSlotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <op>
                                    <Present/>
                                 </op>
                              </PredicateCondition>
                           </cond>
                           <thenStep>
                              <SetStep>
                                 <ref>
                                    <Variable name="internalSlotsList"/>
                                 </ref>
                                 <expr>
                                    <ListConcatExpression>
                                       <exprs>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="internalSlotsList"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </exprs>
                                       <exprs>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="additionalInternalSlotsList"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </exprs>
                                    </ListConcatExpression>
                                 </expr>
                              </SetStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="O"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="MakeBasicObject">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="internalSlotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="O"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="Prototype"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="proto"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="O"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
