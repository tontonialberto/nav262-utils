<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _genContext_ be the running execution context.           1. If _genContext_ does not have a Generator component, return ~non-generator~.           1. Let _generator_ be the Generator component of _genContext_.           1. If _generator_ has an [[AsyncGeneratorState]] internal slot, return ~async~.           1. Else, return ~sync~.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="GetGeneratorKind" retTy="~async~, ~non-generator~, or ~sync~" id="sec-getgeneratorkind" virtualPackage="27 Control Abstraction Objects.5 Generator Objects.3 Generator Abstract Operations.5 GetGeneratorKind ( )" location="https://tc39.es/ecma262/2025/">
         <params/>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="genContext"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <RunningExecutionContext/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="If _genContext_ does not have a Generator component, return ~non-generator~." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="generator"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="genContext"/>
                                       </base>
                                       <prop>
                                          <ComponentProperty name="Generator"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep newLine="true" keyword="else" comma="true">
                           <cond>
                              <HasFieldCondition negation="false">
                                 <ref>
                                    <Variable name="generator"/>
                                 </ref>
                                 <field>
                                    <FieldLiteral name="AsyncGeneratorState"/>
                                 </field>
                              </HasFieldCondition>
                           </cond>
                           <thenStep>
                              <ReturnStep>
                                 <expr>
                                    <EnumLiteral name="async"/>
                                 </expr>
                              </ReturnStep>
                           </thenStep>
                           <elseStep>
                              <ReturnStep>
                                 <expr>
                                    <EnumLiteral name="sync"/>
                                 </expr>
                              </ReturnStep>
                           </elseStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
