<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="             1. Let _F_ be the active function object.             1. Assert: _F_ has a [[Promise]] internal slot whose value is an Object.             1. Let _promise_ be _F_.[[Promise]].             1. Let _alreadyResolved_ be _F_.[[AlreadyResolved]].             1. If _alreadyResolved_.[[Value]] is *true*, return *undefined*.             1. Set _alreadyResolved_.[[Value]] to *true*.             1. Perform RejectPromise(_promise_, _reason_).             1. Return *undefined*.           ">
   <head>
      <BuiltinHead name="PromiseRejectFunction" retTy="unknown" id="sec-promise-reject-functions" virtualPackage="27 Control Abstraction Objects.2 Promise Objects.1 Promise Abstract Operations.3 CreateResolvingFunctions ( promise ).1 Promise Reject Functions" location="https://tc39.es/ecma262/2025/">
