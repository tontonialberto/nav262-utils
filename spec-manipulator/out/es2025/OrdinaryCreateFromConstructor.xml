<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Assert: _intrinsicDefaultProto_ is this specification's name of an intrinsic object. The corresponding object must be an intrinsic that is intended to be used as the [[Prototype]] value of an object.         1. Let _proto_ be ? GetPrototypeFromConstructor(_constructor_, _intrinsicDefaultProto_).         1. If _internalSlotsList_ is present, let _slotsList_ be _internalSlotsList_.         1. Else, let _slotsList_ be a new empty List.         1. Return OrdinaryObjectCreate(_proto_, _slotsList_).       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="OrdinaryCreateFromConstructor" retTy="either a normal completion containing an Object or a throw completion" id="sec-ordinarycreatefromconstructor" virtualPackage="10 Ordinary and Exotic Objects Behaviours.1 Ordinary Object Internal Methods and Internal Slots.13 OrdinaryCreateFromConstructor ( constructor, intrinsicDefaultProto [ , internalSlotsList ] )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="constructor" ty="a function object"/>
         </params>
         <params>
            <NormalParam name="intrinsicDefaultProto" ty="a String"/>
         </params>
         <params>
            <OptionalParam name="internalSlotsList" ty="a List of names of internal slots"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <ExpressionCondition>
                                 <expr>
                                    <YetExpression str="_intrinsicDefaultProto_ is this specification's name of an intrinsic object. The corresponding object must be an intrinsic that is intended to be used as the [[Prototype]] value of an object" block="null"/>
                                 </expr>
                              </ExpressionCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="proto"/>
                           </variable>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
                                    <InvokeAbstractOperationExpression name="GetPrototypeFromConstructor">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="constructor"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="intrinsicDefaultProto"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep newLine="true" keyword="else" comma="true">
                           <cond>
                              <PredicateCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="internalSlotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <op>
                                    <Present/>
                                 </op>
                              </PredicateCondition>
                           </cond>
                           <thenStep>
                              <LetStep>
                                 <variable>
                                    <Variable name="slotsList"/>
                                 </variable>
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="internalSlotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                              </LetStep>
                           </thenStep>
                           <elseStep>
                              <LetStep>
                                 <variable>
                                    <Variable name="slotsList"/>
                                 </variable>
                                 <expr>
                                    <ListExpression>
                                       <entries/>
                                    </ListExpression>
                                 </expr>
                              </LetStep>
                           </elseStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <InvokeAbstractOperationExpression name="OrdinaryObjectCreate">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="proto"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="slotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
