<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. If DaysInYear(YearFromTime(_t_)) is *366*&lt;sub&gt;𝔽&lt;/sub&gt;, return *1*&lt;sub&gt;𝔽&lt;/sub&gt;; else return *+0*&lt;sub&gt;𝔽&lt;/sub&gt;.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="InLeapYear" retTy="*+0*&lt;sub&gt;𝔽&lt;/sub&gt; or *1*&lt;sub&gt;𝔽&lt;/sub&gt;" id="sec-inleapyear" virtualPackage="21 Numbers and Dates.4 Date Objects.1 Overview of Date Objects and Definitions of Abstract Operations.10 InLeapYear ( t )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="t" ty="a finite time value"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep newLine="false" keyword="else" comma="false">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <InvokeAbstractOperationExpression name="DaysInYear">
                                       <args>
                                          <InvokeAbstractOperationExpression name="YearFromTime">
                                             <args>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="t"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </args>
                                          </InvokeAbstractOperationExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </left>
                                 <right>
                                    <NumberLiteral value="366" isNegative="false"/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <ReturnStep>
                                 <expr>
                                    <NumberLiteral value="1" isNegative="false"/>
                                 </expr>
                              </ReturnStep>
                           </thenStep>
                           <elseStep>
                              <ReturnStep>
                                 <expr>
                                    <NumberLiteral value="0" isNegative="false"/>
                                 </expr>
                              </ReturnStep>
                           </elseStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
