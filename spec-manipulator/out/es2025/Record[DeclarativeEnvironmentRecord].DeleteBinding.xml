<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="             1. Assert: _envRec_ has a binding for _N_.             1. If the binding for _N_ in _envRec_ cannot be deleted, return *false*.             1. Remove the binding for _N_ from _envRec_.             1. Return *true*.           ">
   <head>
      <ConcreteMethodHead concMethodName="DeleteBinding" retTy="a normal completion containing a Boolean" id="sec-declarative-environment-records-deletebinding-n" virtualPackage="9 Executable Code and Execution Contexts.1 Environment Records.1 The Environment Record Type Hierarchy.1 Declarative Environment Records.7 DeleteBinding ( N )" location="https://tc39.es/ecma262/2025/" name="DeclarativeEnvironmentRecord.DeleteBinding">
         <receiver>
            <NormalParam name="envRec" ty="a Declarative Environment Record"/>
         </receiver>
         <params>
            <NormalParam name="N" ty="a String"/>
         </params>
      </ConcreteMethodHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <HasBindingCondition negation="false">
                                 <ref>
                                    <Variable name="envRec"/>
                                 </ref>
                                 <binding>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="N"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </binding>
                              </HasBindingCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="If the binding for _N_ in _envRec_ cannot be deleted, return *false*." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Remove the binding for _N_ from _envRec_." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <TrueLiteral/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
