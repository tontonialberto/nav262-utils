                                             <steps>
                                                <SubStep directive="null">
                                                   <step>
                                                      <YetStep>
                                                         <expr>
                                                            <YetExpression str="Let _patternSymbol_ be |Pattern[~UnicodeMode, ~UnicodeSetsMode]|." block="null"/>
                                                         </expr>
                                                      </YetStep>
