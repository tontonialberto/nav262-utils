      <AbstractOperationHead isHostDefined="false" name="EscapeRegExpPattern" retTy="a String" id="sec-escaperegexppattern" virtualPackage="22 Text Processing.2 RegExp (Regular Expression) Objects.6 Properties of the RegExp Prototype Object.13 get RegExp.prototype.source.1 EscapeRegExpPattern ( P, F )" location="https://tc39.es/ecma262/2025/">
