                                             <ref>
                                                <Variable name="isTypedArray"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </left>
                                       <right>
                                          <TrueLiteral/>
                                       </right>
                                    </IsAreCondition>
                                 </left>
                                 <op>
