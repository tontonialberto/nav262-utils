                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="calleeContext"/>
                           </variable>
                           <expr>
                              <RecordExpression tname="ExecutionContext">
                                 <fields/>
                              </RecordExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="Function"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="F"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="calleeRealm"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="F"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="Realm"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="Realm"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="calleeRealm"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="ScriptOrModule"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="F"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="ScriptOrModule"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="localEnv"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="NewFunctionEnvironment">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="F"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="newTarget"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="LexicalEnvironment"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="localEnv"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="VariableEnvironment"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="localEnv"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="calleeContext"/>
                                 </base>
                                 <prop>
                                    <ComponentProperty name="PrivateEnvironment"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="F"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="PrivateEnvironment"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="If _callerContext_ is not already suspended, suspend _callerContext_." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <PushContextStep>
                           <ref>
                              <Variable name="calleeContext"/>
                           </ref>
                        </PushContextStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <NoteStep note="Any exception objects produced after this point are associated with _calleeRealm_."/>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="calleeContext"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
