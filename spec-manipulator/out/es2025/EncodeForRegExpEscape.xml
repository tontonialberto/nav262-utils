                                    <YetExpression str="_cp_ is matched by either |WhiteSpace| or |LineTerminator|, or _cp_ has the same numeric value as a leading surrogate or trailing surrogate, then">
                                       <block>
                                          <StepBlock>
                                             <steps>
                                                <SubStep directive="null">
                                                   <step>
                                                      <LetStep>
                                                         <variable>
                                                            <Variable name="cpNum"/>
                                                         </variable>
