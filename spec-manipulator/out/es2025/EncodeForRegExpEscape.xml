                                             <step>
                                                <ReturnStep>
                                                   <expr>
                                                      <StringConcatExpression>
                                                         <exprs>
                                                            <HexLiteral hex="92" name="REVERSE SOLIDUS"/>
                                                         </exprs>
                                                         <exprs>
                                                            <InvokeAbstractOperationExpression name="UTF16EncodeCodePoint">
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="cp"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                            </InvokeAbstractOperationExpression>
                                                         </exprs>
                                                      </StringConcatExpression>
                                                   </expr>
                                                </ReturnStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                           <elseStep>
                              <IfStep elseStep="null">
                                 <cond>
                                    <ExpressionCondition>
                                       <expr>
                                          <YetExpression str="_cp_ is a code point listed in the “Code Point” column of &lt;emu-xref href=&#34;#table-controlescape-code-point-values&#34;&gt;&lt;/emu-xref&gt;" block="null"/>
                                       </expr>
                                    </ExpressionCondition>
                                 </cond>
                                 <thenStep>
                                    <BlockStep>
                                       <block>
                                          <StepBlock>
                                             <steps>
                                                <SubStep directive="null">
                                                   <step>
                                                      <YetStep>
                                                         <expr>
                                                            <YetExpression str="Return the string-concatenation of 0x005C (REVERSE SOLIDUS) and the string in the “ControlEscape” column of the row whose “Code Point” column contains _cp_." block="null"/>
                                                         </expr>
                                                      </YetStep>
                                                   </step>
                                                </SubStep>
                                             </steps>
                                          </StepBlock>
                                       </block>
                                    </BlockStep>
                                 </thenStep>
                              </IfStep>
                           </elseStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="otherPunctuators"/>
                           </variable>
                           <expr>
                              <StringConcatExpression>
                                 <exprs>
                                    <StringLiteral s=",-=&lt;&gt;#&amp;!%:;@~'`"/>
                                 </exprs>
                                 <exprs>
                                    <HexLiteral hex="34" name="QUOTATION MARK"/>
                                 </exprs>
                              </StringConcatExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
