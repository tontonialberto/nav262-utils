                                                                     <ref>
                                                                        <Variable name="cpNum"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </left>
                                                               <op>
                                                                  <LessThanEqual/>
                                                               </op>
                                                               <right>
                                                                  <HexLiteral hex="255" name="null"/>
                                                               </right>
                                                            </BinaryCondition>
                                                         </cond>
                                                         <thenStep>
                                                            <BlockStep>
                                                               <block>
                                                                  <StepBlock>
                                                                     <steps>
                                                                        <SubStep directive="null">
                                                                           <step>
                                                                              <LetStep>
                                                                                 <variable>
                                                                                    <Variable name="hex"/>
                                                                                 </variable>
                                                                                 <expr>
                                                                                    <InvokeNumericMethodExpression name="Number::toString">
                                                                                       <args>
                                                                                          <ConversionExpression>
                                                                                             <op>
                                                                                                <ToNumber/>
                                                                                             </op>
                                                                                             <expr>
                                                                                                <ReferenceExpression>
                                                                                                   <ref>
                                                                                                      <Variable name="cpNum"/>
                                                                                                   </ref>
                                                                                                </ReferenceExpression>
                                                                                             </expr>
                                                                                          </ConversionExpression>
                                                                                       </args>
                                                                                       <args>
                                                                                          <DecimalMathValueLiteral n="16"/>
                                                                                       </args>
                                                                                    </InvokeNumericMethodExpression>
                                                                                 </expr>
                                                                              </LetStep>
                                                                           </step>
                                                                        </SubStep>
                                                                     </steps>
                                                                     <steps>
                                                                        <SubStep directive="null">
                                                                           <step>
                                                                              <ReturnStep>
