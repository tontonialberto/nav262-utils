<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _privateEnv_ be the running execution context's PrivateEnvironment.           1. Assert: _privateEnv_ is not *null*.           1. Let _privateName_ be ResolvePrivateIdentifier(_privateEnv_, _privateIdentifier_).           1. Return the Reference Record { [[Base]]: _baseValue_, [[ReferencedName]]: _privateName_, [[Strict]]: *true*, [[ThisValue]]: ~empty~ }.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="MakePrivateReference" retTy="a Reference Record" id="sec-makeprivatereference" virtualPackage="6 ECMAScript Data Types and Values.2 ECMAScript Specification Types.5 The Reference Record Specification Type.9 MakePrivateReference ( baseValue, privateIdentifier )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="baseValue" ty="an ECMAScript language value"/>
         </params>
         <params>
            <NormalParam name="privateIdentifier" ty="a String"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="privateEnv"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <RunningExecutionContext/>
                                       </base>
                                       <prop>
                                          <ComponentProperty name="PrivateEnvironment"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="true">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="privateEnv"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <NullLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="privateName"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="ResolvePrivateIdentifier">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="privateEnv"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="privateIdentifier"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <RecordExpression tname="Reference Record">
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Base"/>
                                       </field>
                                       <value>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="baseValue"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </value>
                                    </RecordField>
                                 </fields>
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="ReferencedName"/>
                                       </field>
                                       <value>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="privateName"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </value>
                                    </RecordField>
                                 </fields>
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Strict"/>
                                       </field>
                                       <value>
                                          <TrueLiteral/>
                                       </value>
                                    </RecordField>
                                 </fields>
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="ThisValue"/>
                                       </field>
                                       <value>
                                          <EnumLiteral name="empty"/>
                                       </value>
                                    </RecordField>
                                 </fields>
                              </RecordExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
