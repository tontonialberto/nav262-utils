                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <InvokeAbstractOperationExpression name="IsConstructor">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="target"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </left>
                                 <right>
                                    <TrueLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
