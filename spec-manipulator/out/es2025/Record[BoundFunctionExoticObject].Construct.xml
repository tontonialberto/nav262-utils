                                    <PropertyReference>
                                       <base>
                                          <Variable name="F"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="BoundArguments"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="args"/>
                           </variable>
                           <expr>
                              <ListConcatExpression>
                                 <exprs>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="boundArgs"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </exprs>
                                 <exprs>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="argumentsList"/>
