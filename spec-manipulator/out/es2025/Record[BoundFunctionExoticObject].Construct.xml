                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="newTarget"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </left>
                                 <right>
                                    <TrueLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <SetStep>
                                 <ref>
                                    <Variable name="newTarget"/>
                                 </ref>
                                 <expr>
