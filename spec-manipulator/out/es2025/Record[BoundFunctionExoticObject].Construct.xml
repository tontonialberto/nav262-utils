                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <InvokeAbstractOperationExpression name="SameValue">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="F"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
