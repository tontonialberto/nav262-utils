<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _func_ be the *this* value.           1. If _func_ is an Object, _func_ has a [[SourceText]] internal slot, _func_.[[SourceText]] is a sequence of Unicode code points, and HostHasSourceTextAvailable(_func_) is *true*, then             1. Return CodePointsToString(_func_.[[SourceText]]).           1. If _func_ is a &lt;emu-xref href=&#34;#sec-built-in-function-objects&#34;&gt;built-in function object&lt;/emu-xref&gt;, return an implementation-defined String source code representation of _func_. The representation must have the syntax of a |NativeFunction|. Additionally, if _func_ has an [[InitialName]] internal slot and _func_.[[InitialName]] is a String, the portion of the returned String that would be matched by |NativeFunctionAccessor?| |PropertyName| must be the value of _func_.[[InitialName]].           1. If _func_ is an Object and IsCallable(_func_) is *true*, return an implementation-defined String source code representation of _func_. The representation must have the syntax of a |NativeFunction|.           1. Throw a *TypeError* exception.         ">
   <head>
      <BuiltinHead name="Function.prototype.toString" retTy="unknown" id="sec-function.prototype.tostring" virtualPackage="20 Fundamental Objects.2 Function Objects.3 Properties of the Function Prototype Object.5 Function.prototype.toString ( )" location="https://tc39.es/ecma262/2025/">
         <params/>
      </BuiltinHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="func"/>
                           </variable>
                           <expr>
                              <ThisLiteral/>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <TypeCheckCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="func"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <ty>
                                    <Type value="an Object"/>
                                 </ty>
                              </TypeCheckCondition>
                           </cond>
                           <thenStep>
                              <YetStep>
                                 <expr>
                                    <YetExpression str="_func_ has a [[SourceText]] internal slot, _func_.[[SourceText]] is a sequence of Unicode code points, and HostHasSourceTextAvailable(_func_) is *true*, then">
                                       <block>
                                          <StepBlock>
                                             <steps>
                                                <SubStep directive="null">
                                                   <step>
                                                      <ReturnStep>
                                                         <expr>
                                                            <InvokeAbstractOperationExpression name="CodePointsToString">
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <PropertyReference>
                                                                           <base>
                                                                              <Variable name="func"/>
                                                                           </base>
                                                                           <prop>
                                                                              <FieldProperty name="SourceText"/>
                                                                           </prop>
                                                                        </PropertyReference>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                            </InvokeAbstractOperationExpression>
                                                         </expr>
                                                      </ReturnStep>
                                                   </step>
                                                </SubStep>
                                             </steps>
                                          </StepBlock>
                                       </block>
                                    </YetExpression>
                                 </expr>
                              </YetStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="If _func_ is a &lt;emu-xref href=&#34;#sec-built-in-function-objects&#34;&gt;built-in function object&lt;/emu-xref&gt;, return an implementation-defined String source code representation of _func_. The representation must have the syntax of a |NativeFunction|. Additionally, if _func_ has an [[InitialName]] internal slot and _func_.[[InitialName]] is a String, the portion of the returned String that would be matched by |NativeFunctionAccessor?| |PropertyName| must be the value of _func_.[[InitialName]]." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <CompoundCondition>
                                 <left>
                                    <TypeCheckCondition negation="false">
                                       <expr>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="func"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </expr>
                                       <ty>
                                          <Type value="an Object"/>
                                       </ty>
                                    </TypeCheckCondition>
                                 </left>
                                 <op>
                                    <And/>
                                 </op>
                                 <right>
                                    <IsAreCondition negation="false">
                                       <left>
                                          <InvokeAbstractOperationExpression name="IsCallable">
                                             <args>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="func"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </args>
                                          </InvokeAbstractOperationExpression>
                                       </left>
                                       <right>
                                          <TrueLiteral/>
                                       </right>
                                    </IsAreCondition>
                                 </right>
                              </CompoundCondition>
                           </cond>
                           <thenStep>
                              <YetStep>
                                 <expr>
                                    <YetExpression str="return an implementation-defined String source code representation of _func_. The representation must have the syntax of a |NativeFunction|." block="null"/>
                                 </expr>
                              </YetStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ThrowStep name="TypeError"/>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
