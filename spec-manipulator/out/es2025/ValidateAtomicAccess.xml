<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _length_ be TypedArrayLength(_taRecord_).           1. Let _accessIndex_ be ? ToIndex(_requestIndex_).           1. Assert: _accessIndex_ ≥ 0.           1. If _accessIndex_ ≥ _length_, throw a *RangeError* exception.           1. Let _typedArray_ be _taRecord_.[[Object]].           1. Let _elementSize_ be TypedArrayElementSize(_typedArray_).           1. Let _offset_ be _typedArray_.[[ByteOffset]].           1. Return (_accessIndex_ × _elementSize_) + _offset_.         ">
