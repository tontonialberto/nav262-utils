                                          <TrueLiteral/>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
