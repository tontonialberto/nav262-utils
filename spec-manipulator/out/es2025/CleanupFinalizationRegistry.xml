<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="       1. Assert: _finalizationRegistry_ has [[Cells]] and [[CleanupCallback]] internal slots.       1. Let _callback_ be _finalizationRegistry_.[[CleanupCallback]].       1. While _finalizationRegistry_.[[Cells]] contains a Record _cell_ such that _cell_.[[WeakRefTarget]] is ~empty~, an implementation may perform the following steps:         1. Choose any such _cell_.         1. Remove _cell_ from _finalizationRegistry_.[[Cells]].         1. Perform ? HostCallJobCallback(_callback_, *undefined*, « _cell_.[[HeldValue]] »).       1. Return ~unused~.     ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="CleanupFinalizationRegistry" retTy="either a normal completion containing ~unused~ or a throw completion" id="sec-cleanup-finalization-registry" virtualPackage="9 Executable Code and Execution Contexts.12 CleanupFinalizationRegistry ( finalizationRegistry )" location="https://tc39.es/ecma262/2025/">
