<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Assert: _method_.[[Kind]] is either ~method~ or ~accessor~.         1. If the host is a web browser, then           1. Perform ? HostEnsureCanAddPrivateElement(_O_).         1. Let _entry_ be PrivateElementFind(_O_, _method_.[[Key]]).         1. If _entry_ is not ~empty~, throw a *TypeError* exception.         1. Append _method_ to _O_.[[PrivateElements]].         1. Return ~unused~.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="PrivateMethodOrAccessorAdd" retTy="either a normal completion containing ~unused~ or a throw completion" id="sec-privatemethodoraccessoradd" virtualPackage="7 Abstract Operations.3 Operations on Objects.28 PrivateMethodOrAccessorAdd ( O, method )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="O" ty="an Object"/>
         </params>
         <params>
            <NormalParam name="method" ty="a Private Element"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="method"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="Kind"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <EnumLiteral name="method"/>
                                 </right>
                                 <right>
                                    <EnumLiteral name="accessor"/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <ExpressionCondition>
                                 <expr>
                                    <YetExpression str="the host is a web browser" block="null"/>
                                 </expr>
                              </ExpressionCondition>
                           </cond>
                           <thenStep>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <PerformStep>
                                                   <expr>
                                                      <ReturnIfAbruptExpression check="true">
                                                         <expr>
                                                            <InvokeAbstractOperationExpression name="HostEnsureCanAddPrivateElement">
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="O"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                            </InvokeAbstractOperationExpression>
                                                         </expr>
                                                      </ReturnIfAbruptExpression>
                                                   </expr>
                                                </PerformStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="entry"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="PrivateElementFind">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="O"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="method"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="Key"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="true">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="entry"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <EnumLiteral name="empty"/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AppendStep>
                           <elem>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="method"/>
                                 </ref>
                              </ReferenceExpression>
                           </elem>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="O"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="PrivateElements"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                        </AppendStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <EnumLiteral name="unused"/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
