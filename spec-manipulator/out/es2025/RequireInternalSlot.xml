<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. If _O_ is not an Object, throw a *TypeError* exception.         1. If _O_ does not have an _internalSlot_ internal slot, throw a *TypeError* exception.         1. Return ~unused~.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="RequireInternalSlot" retTy="either a normal completion containing ~unused~ or a throw completion" id="sec-requireinternalslot" virtualPackage="10 Ordinary and Exotic Objects Behaviours.1 Ordinary Object Internal Methods and Internal Slots.15 RequireInternalSlot ( O, internalSlot )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="O" ty="an ECMAScript language value"/>
         </params>
         <params>
            <NormalParam name="internalSlot" ty="a String"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <TypeCheckCondition negation="true">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="O"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <ty>
                                    <Type value="an Object"/>
                                 </ty>
                              </TypeCheckCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <HasFieldCondition negation="true">
                                 <ref>
                                    <Variable name="O"/>
                                 </ref>
                                 <field>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="internalSlot"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </field>
                              </HasFieldCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <EnumLiteral name="unused"/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
