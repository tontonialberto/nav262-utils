<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _desc_ be OrdinaryGetOwnProperty(_args_, _P_).           1. If _desc_ is *undefined*, return *undefined*.           1. Let _map_ be _args_.[[ParameterMap]].           1. Let _isMapped_ be ! HasOwnProperty(_map_, _P_).           1. If _isMapped_ is *true*, then             1. Set _desc_.[[Value]] to ! Get(_map_, _P_).           1. Return _desc_.         ">
