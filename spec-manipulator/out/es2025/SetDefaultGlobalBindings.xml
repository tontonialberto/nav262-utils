<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Let _global_ be _realmRec_.[[GlobalObject]].         1. For each property of the Global Object specified in clause &lt;emu-xref href=&#34;#sec-global-object&#34;&gt;&lt;/emu-xref&gt;, do           1. Let _name_ be the String value of the property name.           1. Let _desc_ be the fully populated data Property Descriptor for the property, containing the specified attributes for the property. For properties listed in &lt;emu-xref href=&#34;#sec-function-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt;, &lt;emu-xref href=&#34;#sec-constructor-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt;, or &lt;emu-xref href=&#34;#sec-other-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt; the value of the [[Value]] attribute is the corresponding intrinsic object from _realmRec_.           1. Perform ? DefinePropertyOrThrow(_global_, _name_, _desc_).         1. Return ~unused~.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="SetDefaultGlobalBindings" retTy="either a normal completion containing ~unused~ or a throw completion" id="sec-setdefaultglobalbindings" virtualPackage="9 Executable Code and Execution Contexts.3 Realms.3 SetDefaultGlobalBindings ( realmRec )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="realmRec" ty="a Realm Record"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="global"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="realmRec"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="GlobalObject"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="For each property of the Global Object specified in clause &lt;emu-xref href=&#34;#sec-global-object&#34;&gt;&lt;/emu-xref&gt;, do">
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <YetStep>
                                                   <expr>
                                                      <YetExpression str="Let _name_ be the String value of the property name." block="null"/>
                                                   </expr>
                                                </YetStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <YetStep>
                                                   <expr>
                                                      <YetExpression str="Let _desc_ be the fully populated data Property Descriptor for the property, containing the specified attributes for the property. For properties listed in &lt;emu-xref href=&#34;#sec-function-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt;, &lt;emu-xref href=&#34;#sec-constructor-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt;, or &lt;emu-xref href=&#34;#sec-other-properties-of-the-global-object&#34;&gt;&lt;/emu-xref&gt; the value of the [[Value]] attribute is the corresponding intrinsic object from _realmRec_." block="null"/>
                                                   </expr>
                                                </YetStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <PerformStep>
                                                   <expr>
                                                      <ReturnIfAbruptExpression check="true">
                                                         <expr>
                                                            <InvokeAbstractOperationExpression name="DefinePropertyOrThrow">
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="global"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="name"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="desc"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                            </InvokeAbstractOperationExpression>
                                                         </expr>
                                                      </ReturnIfAbruptExpression>
                                                   </expr>
                                                </PerformStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </YetExpression>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <EnumLiteral name="unused"/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
