                                 </expr>
                              </ExpressionCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="F"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="IsClassConstructor"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <TrueLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <LetStep>
                                                   <variable>
                                                      <Variable name="error"/>
                                                   </variable>
                                                   <expr>
                                                      <ErrorObjectLiteral name="TypeError"/>
                                                   </expr>
                                                </LetStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <NoteStep note="_error_ is created in _calleeContext_ with _F_'s associated Realm Record."/>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <RemoveContextStep>
                                                   <context>
                                                      <Variable name="calleeContext"/>
                                                   </context>
                                                   <restoreTarget>
                                                      <Context>
                                                         <ref>
                                                            <Variable name="callerContext"/>
                                                         </ref>
                                                      </Context>
                                                   </restoreTarget>
                                                </RemoveContextStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <ReturnStep>
                                                   <expr>
                                                      <InvokeAbstractOperationExpression name="ThrowCompletion">
                                                         <args>
                                                            <ReferenceExpression>
                                                               <ref>
                                                                  <Variable name="error"/>
                                                               </ref>
                                                            </ReferenceExpression>
                                                         </args>
                                                      </InvokeAbstractOperationExpression>
                                                   </expr>
                                                </ReturnStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <PerformStep>
                           <expr>
                              <InvokeAbstractOperationExpression name="OrdinaryCallBindThis">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="F"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="calleeContext"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="thisArgument"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </PerformStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="result"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="Completion">
                                 <args>
                                    <InvokeAbstractOperationExpression name="OrdinaryCallEvaluateBody">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="F"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="argumentsList"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep>
                     <directive>
                        <Directive name="id">
                           <values>step-call-pop-context-stack</values>
                        </Directive>
                     </directive>
                     <step>
                        <RemoveContextStep>
                           <context>
                              <Variable name="calleeContext"/>
                           </context>
                           <restoreTarget>
                              <Context>
                                 <ref>
                                    <Variable name="callerContext"/>
                                 </ref>
                              </Context>
                           </restoreTarget>
                        </RemoveContextStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <PredicateCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="result"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <op>
                                    <Return/>
                                 </op>
                              </PredicateCondition>
                           </cond>
                           <thenStep>
                              <ReturnStep>
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="result"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="Value"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                              </ReturnStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <PredicateCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="result"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <op>
                                    <Throw/>
                                 </op>
                              </PredicateCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="result"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
