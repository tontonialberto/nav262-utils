                                                <ToMath/>
                                             </op>
                                             <expr>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="cu"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </expr>
                                          </ConversionExpression>
                                       </left>
                                       <op>
                                          <LessThan/>
                                       </op>
                                       <right>
                                          <DecimalMathValueLiteral n="128"/>
                                       </right>
                                    </BinaryCondition>
                                 </right>
                              </CompoundCondition>
                           </cond>
                           <thenStep>
