                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <CompoundCondition>
                                 <left>
                                    <BinaryCondition>
                                       <left>
                                          <ConversionExpression>
                                             <op>
                                                <ToMath/>
                                             </op>
                                             <expr>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="ch"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </expr>
                                          </ConversionExpression>
                                       </left>
                                       <op>
                                          <GreaterThanEqual/>
                                       </op>
                                       <right>
                                          <DecimalMathValueLiteral n="128"/>
                                       </right>
                                    </BinaryCondition>
                                 </left>
                                 <op>
                                    <And/>
                                 </op>
                                 <right>
                                    <BinaryCondition>
                                       <left>
