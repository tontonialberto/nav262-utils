                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="rer"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="IgnoreCase"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <FalseLiteral/>
                                 </right>
                              </IsAreCondition>
