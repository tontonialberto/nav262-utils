<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Assert: IsDetachedBuffer(_srcBuffer_) is *false*.           1. Let _targetBuffer_ be ? &lt;emu-meta suppress-effects=&#34;user-code&#34;&gt;AllocateArrayBuffer(%ArrayBuffer%, _srcLength_)&lt;/emu-meta&gt;.           1. Let _srcBlock_ be _srcBuffer_.[[ArrayBufferData]].           1. Let _targetBlock_ be _targetBuffer_.[[ArrayBufferData]].           1. Perform CopyDataBlockBytes(_targetBlock_, 0, _srcBlock_, _srcByteOffset_, _srcLength_).           1. Return _targetBuffer_.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="CloneArrayBuffer" retTy="either a normal completion containing an Array Buffer or a throw completion" id="sec-clonearraybuffer" virtualPackage="25 Structured Data.1 ArrayBuffer Objects.3 Abstract Operations For ArrayBuffer Objects.6 CloneArrayBuffer ( srcBuffer, srcByteOffset, srcLength )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="srcBuffer" ty="a Shared Array Buffer or an Array Buffer"/>
         </params>
         <params>
            <NormalParam name="srcByteOffset" ty="a math value"/>
         </params>
         <params>
            <NormalParam name="srcLength" ty="a math value"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <InvokeAbstractOperationExpression name="IsDetachedBuffer">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="srcBuffer"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </left>
                                 <right>
                                    <FalseLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="targetBuffer"/>
                           </variable>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
                                    <InvokeAbstractOperationExpression name="AllocateArrayBuffer">
                                       <args>
                                          <IntrinsicExpression>
                                             <intr>
                                                <Intrinsic base="ArrayBuffer">
                                                   <props/>
                                                </Intrinsic>
                                             </intr>
                                          </IntrinsicExpression>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="srcLength"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="srcBlock"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="srcBuffer"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="ArrayBufferData"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="targetBlock"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="targetBuffer"/>
                                       </base>
                                       <prop>
                                          <FieldProperty name="ArrayBufferData"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <PerformStep>
                           <expr>
                              <InvokeAbstractOperationExpression name="CopyDataBlockBytes">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="targetBlock"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <DecimalMathValueLiteral n="0"/>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="srcBlock"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="srcByteOffset"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="srcLength"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </PerformStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="targetBuffer"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
