<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _runningContext_ be the running execution context.           1. Let _asyncContext_ be a copy of _runningContext_.           1. NOTE: Copying the execution state is required for AsyncBlockStart to resume its execution. It is ill-defined to resume a currently executing context.           1. Perform AsyncBlockStart(_promiseCapability_, _asyncFunctionBody_, _asyncContext_).           1. Return ~unused~.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="AsyncFunctionStart" retTy="~unused~" id="sec-async-functions-abstract-operations-async-function-start" virtualPackage="27 Control Abstraction Objects.7 AsyncFunction Objects.5 Async Functions Abstract Operations.1 AsyncFunctionStart ( promiseCapability, asyncFunctionBody )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="promiseCapability" ty="a Promise Capability Record"/>
         </params>
         <params>
            <NormalParam name="asyncFunctionBody" ty="an abstract closure, an |ExpressionBody| Parse Node, or a |FunctionBody| Parse Node"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="runningContext"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <RunningExecutionContext/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Let _asyncContext_ be a copy of _runningContext_." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <NoteStep note="Copying the execution state is required for AsyncBlockStart to resume its execution. It is ill-defined to resume a currently executing context."/>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <PerformStep>
                           <expr>
                              <InvokeAbstractOperationExpression name="AsyncBlockStart">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="promiseCapability"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="asyncFunctionBody"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="asyncContext"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </PerformStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <EnumLiteral name="unused"/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
