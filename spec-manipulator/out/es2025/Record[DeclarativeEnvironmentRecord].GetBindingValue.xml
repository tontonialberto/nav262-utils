<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="             1. Assert: _envRec_ has a binding for _N_.             1. If the binding for _N_ in _envRec_ is an uninitialized binding, throw a *ReferenceError* exception.             1. Return the value currently bound to _N_ in _envRec_.           ">
   <head>
      <ConcreteMethodHead concMethodName="GetBindingValue" retTy="either a normal completion containing an ECMAScript language value or a throw completion" id="sec-declarative-environment-records-getbindingvalue-n-s" virtualPackage="9 Executable Code and Execution Contexts.1 Environment Records.1 The Environment Record Type Hierarchy.1 Declarative Environment Records.6 GetBindingValue ( N, S )" location="https://tc39.es/ecma262/2025/" name="DeclarativeEnvironmentRecord.GetBindingValue">
         <receiver>
            <NormalParam name="envRec" ty="a Declarative Environment Record"/>
         </receiver>
         <params>
            <NormalParam name="N" ty="a String"/>
         </params>
         <params>
            <NormalParam name="S" ty="a Boolean"/>
         </params>
      </ConcreteMethodHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <HasBindingCondition negation="false">
                                 <ref>
                                    <Variable name="envRec"/>
                                 </ref>
                                 <binding>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="N"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </binding>
                              </HasBindingCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="If the binding for _N_ in _envRec_ is an uninitialized binding, throw a *ReferenceError* exception." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Return the value currently bound to _N_ in _envRec_." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
