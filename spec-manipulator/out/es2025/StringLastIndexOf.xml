<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Let _len_ be the length of _string_.           1. Let _searchLen_ be the length of _searchValue_.           1. Assert: _fromIndex_ + _searchLen_ ≤ _len_.           1. For each integer _i_ such that 0 ≤ _i_ ≤ _fromIndex_, in descending order, do             1. Let _candidate_ be the substring of _string_ from _i_ to _i_ + _searchLen_.             1. If _candidate_ is _searchValue_, return _i_.           1. Return ~not-found~.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="StringLastIndexOf" retTy="a math value or ~not-found~" id="sec-stringlastindexof" virtualPackage="6 ECMAScript Data Types and Values.1 ECMAScript Language Types.4 The String Type.2 StringLastIndexOf ( string, searchValue, fromIndex )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="string" ty="a String"/>
         </params>
         <params>
            <NormalParam name="searchValue" ty="a String"/>
         </params>
         <params>
            <NormalParam name="fromIndex" ty="a math value"/>
         </params>
      </AbstractOperationHead>
   </head>
