                                       <ref>
                                          <Variable name="searchValue"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                              </LengthExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <BinaryCondition>
                                 <left>
                                    <BinaryExpression>
                                       <left>
