                                    <LessThanEqual/>
                                 </op>
                                 <right>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="len"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </right>
                              </BinaryCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ForEachIntegerStep lowInclusive="true" highInclusive="true" ascending="false">
                           <variable>
                              <Variable name="i"/>
                           </variable>
                           <low>
                              <DecimalMathValueLiteral n="0"/>
                           </low>
                           <high>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="fromIndex"/>
                                 </ref>
                              </ReferenceExpression>
                           </high>
                           <body>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <LetStep>
                                                   <variable>
                                                      <Variable name="candidate"/>
