<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. If _O_.[[PrivateElements]] contains a PrivateElement _pe_ such that _pe_.[[Key]] is _P_, then           1. Return _pe_.         1. Return ~empty~.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="PrivateElementFind" retTy="a Private Element or ~empty~" id="sec-privateelementfind" virtualPackage="7 Abstract Operations.3 Operations on Objects.26 PrivateElementFind ( O, P )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="O" ty="an Object"/>
         </params>
         <params>
            <NormalParam name="P" ty="a Private Name"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <ContainsSuchThatCondition negation="false">
                                 <list>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
