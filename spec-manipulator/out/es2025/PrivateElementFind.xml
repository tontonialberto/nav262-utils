                                    <SuchThat tyOpt="a Private Element">
                                       <x>
                                          <Variable name="pe"/>
                                       </x>
                                       <cond>
                                          <IsAreCondition negation="false">
                                             <left>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <PropertyReference>
                                                         <base>
                                                            <Variable name="pe"/>
                                                         </base>
                                                         <prop>
