                                                      </PropertyReference>
                                                   </ref>
                                                </ReferenceExpression>
                                             </left>
                                             <right>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="P"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </right>
                                          </IsAreCondition>
                                       </cond>
                                    </SuchThat>
                                 </target>
                              </ContainsSuchThatCondition>
                           </cond>
                           <thenStep>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
