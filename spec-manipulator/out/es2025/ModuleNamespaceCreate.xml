<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. Assert: _module_.[[Namespace]] is ~empty~.           1. Let _internalSlotsList_ be the internal slots listed in &lt;emu-xref href=&#34;#table-internal-slots-of-module-namespace-exotic-objects&#34;&gt;&lt;/emu-xref&gt;.           1. Let _M_ be MakeBasicObject(_internalSlotsList_).           1. Set _M_'s essential internal methods to the definitions specified in &lt;emu-xref href=&#34;#sec-module-namespace-exotic-objects&#34;&gt;&lt;/emu-xref&gt;.           1. Set _M_.[[Module]] to _module_.           1. Let _sortedExports_ be a List whose elements are the elements of _exports_, sorted according to lexicographic code unit order.           1. Set _M_.[[Exports]] to _sortedExports_.           1. Create own properties of _M_ corresponding to the definitions in &lt;emu-xref href=&#34;#sec-module-namespace-objects&#34;&gt;&lt;/emu-xref&gt;.           1. Set _module_.[[Namespace]] to _M_.           1. Return _M_.         ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="ModuleNamespaceCreate" retTy="a Module Namespace Exotic Object" id="sec-modulenamespacecreate" virtualPackage="10 Ordinary and Exotic Objects Behaviours.4 Built-in Exotic Object Internal Methods and Slots.6 Module Namespace Exotic Objects.12 ModuleNamespaceCreate ( module, exports )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="module" ty="a Module Record"/>
         </params>
         <params>
            <NormalParam name="exports" ty="a List of Strings"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <PropertyReference>
                                             <base>
                                                <Variable name="module"/>
                                             </base>
                                             <prop>
                                                <FieldProperty name="Namespace"/>
                                             </prop>
                                          </PropertyReference>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <EnumLiteral name="empty"/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="internalSlotsList"/>
                           </variable>
                           <expr>
                              <XRefExpression id="table-internal-slots-of-module-namespace-exotic-objects">
                                 <kind>
                                    <InternalSlots/>
                                 </kind>
                              </XRefExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="M"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="MakeBasicObject">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="internalSlotsList"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Set _M_'s essential internal methods to the definitions specified in &lt;emu-xref href=&#34;#sec-module-namespace-exotic-objects&#34;&gt;&lt;/emu-xref&gt;." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="M"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="Module"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="module"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Let _sortedExports_ be a List whose elements are the elements of _exports_, sorted according to lexicographic code unit order." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="M"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="Exports"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="sortedExports"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <YetStep>
                           <expr>
                              <YetExpression str="Create own properties of _M_ corresponding to the definitions in &lt;emu-xref href=&#34;#sec-module-namespace-objects&#34;&gt;&lt;/emu-xref&gt;." block="null"/>
                           </expr>
                        </YetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <SetStep>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="module"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="Namespace"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="M"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="M"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
