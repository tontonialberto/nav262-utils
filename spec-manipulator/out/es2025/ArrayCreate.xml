                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="proto"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </SetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
