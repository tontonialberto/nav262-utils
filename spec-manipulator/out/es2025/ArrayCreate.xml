                                             </base>
                                             <power>
                                                <DecimalMathValueLiteral n="32"/>
                                             </power>
                                          </ExponentiationExpression>
                                       </left>
                                       <op>
                                          <Sub/>
                                       </op>
                                       <right>
                                          <DecimalMathValueLiteral n="1"/>
                                       </right>
                                    </BinaryExpression>
                                 </right>
                              </BinaryCondition>
                           </cond>
