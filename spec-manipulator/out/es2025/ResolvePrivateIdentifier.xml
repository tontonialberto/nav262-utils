                                       <prop>
                                          <FieldProperty name="OuterPrivateEnvironment"/>
                                       </prop>
                                    </PropertyReference>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <IsAreCondition negation="true">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="outerPrivateEnv"/>
                                       </ref>
                                    </ReferenceExpression>
