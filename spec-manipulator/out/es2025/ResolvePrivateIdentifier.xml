                                                         </right>
                                                      </IsAreCondition>
                                                   </cond>
                                                   <thenStep>
                                                      <BlockStep>
                                                         <block>
                                                            <StepBlock>
                                                               <steps>
                                                                  <SubStep directive="null">
                                                                     <step>
                                                                        <ReturnStep>
                                                                           <expr>
                                                                              <ReferenceExpression>
                                                                                 <ref>
                                                                                    <Variable name="pn"/>
                                                                                 </ref>
                                                                              </ReferenceExpression>
                                                                           </expr>
                                                                        </ReturnStep>
                                                                     </step>
                                                                  </SubStep>
                                                               </steps>
                                                            </StepBlock>
                                                         </block>
                                                      </BlockStep>
                                                   </thenStep>
                                                </IfStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </body>
                        </ForEachStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="outerPrivateEnv"/>
                           </variable>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <PropertyReference>
                                       <base>
                                          <Variable name="privateEnv"/>
