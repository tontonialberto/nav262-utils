                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="n"/>
                           </variable>
                           <expr>
                              <InvokeSyntaxDirectedOperationExpression name="MV">
                                 <base>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="parseResult"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </base>
                                 <args/>
                              </InvokeSyntaxDirectedOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <InclusiveIntervalCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="n"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <from>
                                    <DecimalMathValueLiteral n="0"/>
                                 </from>
                                 <to>
                                    <DecimalMathValueLiteral n="255"/>
                                 </to>
                              </InclusiveIntervalCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
