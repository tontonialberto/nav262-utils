<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="           1. If NewTarget is not *undefined*, throw a *TypeError* exception.           1. If _description_ is *undefined*, let _descString_ be *undefined*.           1. Else, let _descString_ be ? ToString(_description_).           1. Return a new Symbol whose [[Description]] is _descString_.         ">
   <head>
      <BuiltinHead name="Symbol" retTy="unknown" id="sec-symbol-description" virtualPackage="20 Fundamental Objects.4 Symbol Objects.1 The Symbol Constructor.1 Symbol ( [ description ] )" location="https://tc39.es/ecma262/2025/">
         <params>
            <OptionalParam name="description" ty="unknown"/>
         </params>
      </BuiltinHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="true">
                                 <left>
                                    <NewTargetLiteral/>
                                 </left>
                                 <right>
                                    <UndefinedLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep newLine="true" keyword="else" comma="true">
                           <cond>
                              <IsAreCondition negation="false">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="description"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <UndefinedLiteral/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <LetStep>
                                 <variable>
                                    <Variable name="descString"/>
                                 </variable>
                                 <expr>
                                    <UndefinedLiteral/>
                                 </expr>
                              </LetStep>
                           </thenStep>
                           <elseStep>
                              <LetStep>
                                 <variable>
                                    <Variable name="descString"/>
                                 </variable>
                                 <expr>
                                    <ReturnIfAbruptExpression check="true">
                                       <expr>
                                          <InvokeAbstractOperationExpression name="ToString">
                                             <args>
                                                <ReferenceExpression>
                                                   <ref>
                                                      <Variable name="description"/>
                                                   </ref>
                                                </ReferenceExpression>
                                             </args>
                                          </InvokeAbstractOperationExpression>
                                       </expr>
                                    </ReturnIfAbruptExpression>
                                 </expr>
                              </LetStep>
                           </elseStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <RecordExpression tname="Symbol">
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Description"/>
                                       </field>
                                       <value>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="descString"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </value>
                                    </RecordField>
                                 </fields>
                              </RecordExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
