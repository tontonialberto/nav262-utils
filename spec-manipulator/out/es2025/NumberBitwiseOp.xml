            <NormalParam name="op" ty="`&amp;`, `^`, or `|`"/>
         </params>
         <params>
            <NormalParam name="x" ty="a Number"/>
         </params>
         <params>
            <NormalParam name="y" ty="a Number"/>
         </params>
      </AbstractOperationHead>
   </head>
