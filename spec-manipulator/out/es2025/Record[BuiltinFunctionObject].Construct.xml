<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. Let _result_ be ? BuiltinCallOrConstruct(_F_, ~uninitialized~, _argumentsList_, _newTarget_).         1. Assert: _result_ is an Object.         1. Return _result_.       ">
   <head>
      <InternalMethodHead methodName="Construct" retTy="either a normal completion containing an Object or a throw completion" id="sec-built-in-function-objects-construct-argumentslist-newtarget" virtualPackage="10 Ordinary and Exotic Objects Behaviours.3 Built-in Function Objects.2 [[Construct]] ( argumentsList, newTarget )" location="https://tc39.es/ecma262/2025/" name="BuiltinFunctionObject.[[Construct]]">
         <receiver>
            <NormalParam name="F" ty="a Builtin Function Object"/>
         </receiver>
         <params>
            <NormalParam name="argumentsList" ty="a List of ECMAScript language values"/>
         </params>
         <params>
            <NormalParam name="newTarget" ty="a constructor"/>
         </params>
      </InternalMethodHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="result"/>
                           </variable>
                           <expr>
                              <ReturnIfAbruptExpression check="true">
                                 <expr>
                                    <InvokeAbstractOperationExpression name="BuiltinCallOrConstruct">
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="F"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                       <args>
                                          <EnumLiteral name="uninitialized"/>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="argumentsList"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                       <args>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="newTarget"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </args>
                                    </InvokeAbstractOperationExpression>
                                 </expr>
                              </ReturnIfAbruptExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AssertStep>
                           <cond>
                              <TypeCheckCondition negation="false">
                                 <expr>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="result"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </expr>
                                 <ty>
                                    <Type value="an Object"/>
                                 </ty>
                              </TypeCheckCondition>
                           </cond>
                        </AssertStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <ReferenceExpression>
                                 <ref>
                                    <Variable name="result"/>
                                 </ref>
                              </ReferenceExpression>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
