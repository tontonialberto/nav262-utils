<?xml version="1.0" encoding="UTF-8"?>
<Algorithm code="         1. If the host is a web browser, then           1. Perform ? HostEnsureCanAddPrivateElement(_O_).         1. Let _entry_ be PrivateElementFind(_O_, _P_).         1. If _entry_ is not ~empty~, throw a *TypeError* exception.         1. Append PrivateElement { [[Key]]: _P_, [[Kind]]: ~field~, [[Value]]: _value_ } to _O_.[[PrivateElements]].         1. Return ~unused~.       ">
   <head>
      <AbstractOperationHead isHostDefined="false" name="PrivateFieldAdd" retTy="either a normal completion containing ~unused~ or a throw completion" id="sec-privatefieldadd" virtualPackage="7 Abstract Operations.3 Operations on Objects.27 PrivateFieldAdd ( O, P, value )" location="https://tc39.es/ecma262/2025/">
         <params>
            <NormalParam name="O" ty="an Object"/>
         </params>
         <params>
            <NormalParam name="P" ty="a Private Name"/>
         </params>
         <params>
            <NormalParam name="value" ty="an ECMAScript language value"/>
         </params>
      </AbstractOperationHead>
   </head>
   <body>
      <BlockStep>
         <block>
            <StepBlock>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <ExpressionCondition>
                                 <expr>
                                    <YetExpression str="the host is a web browser" block="null"/>
                                 </expr>
                              </ExpressionCondition>
                           </cond>
                           <thenStep>
                              <BlockStep>
                                 <block>
                                    <StepBlock>
                                       <steps>
                                          <SubStep directive="null">
                                             <step>
                                                <PerformStep>
                                                   <expr>
                                                      <ReturnIfAbruptExpression check="true">
                                                         <expr>
                                                            <InvokeAbstractOperationExpression name="HostEnsureCanAddPrivateElement">
                                                               <args>
                                                                  <ReferenceExpression>
                                                                     <ref>
                                                                        <Variable name="O"/>
                                                                     </ref>
                                                                  </ReferenceExpression>
                                                               </args>
                                                            </InvokeAbstractOperationExpression>
                                                         </expr>
                                                      </ReturnIfAbruptExpression>
                                                   </expr>
                                                </PerformStep>
                                             </step>
                                          </SubStep>
                                       </steps>
                                    </StepBlock>
                                 </block>
                              </BlockStep>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <LetStep>
                           <variable>
                              <Variable name="entry"/>
                           </variable>
                           <expr>
                              <InvokeAbstractOperationExpression name="PrivateElementFind">
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="O"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                                 <args>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="P"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </args>
                              </InvokeAbstractOperationExpression>
                           </expr>
                        </LetStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <IfStep elseStep="null">
                           <cond>
                              <IsAreCondition negation="true">
                                 <left>
                                    <ReferenceExpression>
                                       <ref>
                                          <Variable name="entry"/>
                                       </ref>
                                    </ReferenceExpression>
                                 </left>
                                 <right>
                                    <EnumLiteral name="empty"/>
                                 </right>
                              </IsAreCondition>
                           </cond>
                           <thenStep>
                              <ThrowStep name="TypeError"/>
                           </thenStep>
                        </IfStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <AppendStep>
                           <elem>
                              <RecordExpression tname="PrivateElement">
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Key"/>
                                       </field>
                                       <value>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="P"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </value>
                                    </RecordField>
                                 </fields>
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Kind"/>
                                       </field>
                                       <value>
                                          <EnumLiteral name="field"/>
                                       </value>
                                    </RecordField>
                                 </fields>
                                 <fields>
                                    <RecordField>
                                       <field>
                                          <FieldLiteral name="Value"/>
                                       </field>
                                       <value>
                                          <ReferenceExpression>
                                             <ref>
                                                <Variable name="value"/>
                                             </ref>
                                          </ReferenceExpression>
                                       </value>
                                    </RecordField>
                                 </fields>
                              </RecordExpression>
                           </elem>
                           <ref>
                              <PropertyReference>
                                 <base>
                                    <Variable name="O"/>
                                 </base>
                                 <prop>
                                    <FieldProperty name="PrivateElements"/>
                                 </prop>
                              </PropertyReference>
                           </ref>
                        </AppendStep>
                     </step>
                  </SubStep>
               </steps>
               <steps>
                  <SubStep directive="null">
                     <step>
                        <ReturnStep>
                           <expr>
                              <EnumLiteral name="unused"/>
                           </expr>
                        </ReturnStep>
                     </step>
                  </SubStep>
               </steps>
            </StepBlock>
         </block>
      </BlockStep>
   </body>
